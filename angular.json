{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "ngx-products-3d": {
      "projectType": "library",
      "root": "projects/ngx-products-3d",
      "sourceRoot": "projects/ngx-products-3d/src",
      "prefix": "products-3d",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "options": {
            "project": "projects/ngx-products-3d/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/ngx-products-3d/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/ngx-products-3d/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/ngx-products-3d/tsconfig.spec.json"
          }
        }
      }
    },
    "products-3d-playground": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/products-3d-playground",
      "sourceRoot": "projects/products-3d-playground/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/products-3d-playground/src/main.ts",
            "tsConfig": "projects/products-3d-playground/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/products-3d-playground/public"
              }
            ],
            "styles": ["projects/products-3d-playground/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "products-3d-playground:build:production"
            },
            "development": {
              "buildTarget": "products-3d-playground:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
